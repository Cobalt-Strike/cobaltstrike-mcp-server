# Cobalt Strike MCP Server Environment Configuration
# Copy this file to .env and customize for your environment

# Cobalt Strike API Configuration
CS_API_BASE_URL=https://localhost:50443
CS_API_USERNAME=resp_api_user
CS_API_PASSWORD=CobaltStrikePassword
CS_API_VERIFY_TLS=false
# CS_API_DURATION_MS=86400000
# CS_API_HTTP_TIMEOUT=30.0

# MCP Server Configuration
# MCP_TRANSPORT=http
# MCP_LISTEN_HOST=127.0.0.1
# MCP_LISTEN_PORT=3000
# MCP_LISTEN_PATH=/mcp
# MCP_SERVER_NAME=Cobalt Strike MCP
# MCP_SERVER_INSTRUCTIONS=
# MCP_ALLOW_REMOTE_BIND=false
# MCP_EXTERNAL_AUTH=false
# MCP_OPERATOR_ID=
# MCP_AUDIT_LOG_FILE=logs/audit.log
# MCP_LOG_LEVEL=INFO

# Cobalt Strike WebSocket Stream Configuration
CS_WS_ENABLED=true
CS_WS_AUTO_START=true
# CS_WS_BUFFER_SIZE=1000
# CS_WS_RECONNECT_SECONDS=2.0

# Set CS_WS_ENABLED=false to disable WebSocket subscriptions. In that mode,
# executeBeaconConsoleAndWait submits console commands through REST and polls
# task status, but streamed console output is unavailable.

# Logging Configuration
# LOG_LEVEL=INFO

# Notes:
# - For Claude Desktop, set MCP_TRANSPORT to stdio.
# - For production, set CS_API_VERIFY_TLS to true and point CS_API_BASE_URL
#   at the team server API endpoint.
# - For debugging, set LOG_LEVEL and MCP_LOG_LEVEL to DEBUG.
